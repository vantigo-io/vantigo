{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["VANTIGO_*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {},
    "test:e2e": {
      "cache": false
    },
    "//#lint": {
      "outputs": []
    },
    "//#format": {
      "cache": false
    }
  }
}
