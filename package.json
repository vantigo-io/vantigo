    "@mantine/core": "^9.3.1",
    "@mantine/hooks": "^9.3.1",
    "better-auth": "^1.6.15",
    "hono": "^4.12.25",
    "wrangler": "^4.99.0",
    "@cloudflare/workers-types": "^4.20260609.1",
