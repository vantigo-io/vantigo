{
  "name": "idp",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:workerd": "wrangler dev",
    "dev:docker": "bun run src/entry.docker.ts",
    "dev": "bun run dev:workerd",
    "build": "bun run scripts/compile.ts",
    "build:web": "bun build ./src/web/index.tsx --outdir ./dist/web",
    "compile": "bun run build",
    "build:all": "bun run build:linux-amd64 && bun run build:linux-arm64 && bun run build:mac-arm64 && bun run build:windows-amd64",
    "build:linux-amd64": "bun run build linux-x64",
    "build:linux-arm64": "bun run build linux-arm64",
    "build:mac-arm64": "bun run build darwin-arm64",
    "build:windows-amd64": "bun run build windows-x64",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "hono": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "@mantine/core": "catalog:",
    "@mantine/hooks": "catalog:",
    "@vantigo/auth": "workspace:*",
    "@vantigo/ui": "workspace:*",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:"
  },
  "devDependencies": {
    "wrangler": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "drizzle-kit": "catalog:"
  }
}
