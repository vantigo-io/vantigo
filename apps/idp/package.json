{
  "name": "idp",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:workerd": "wrangler dev",
    "dev:docker": "bun run src/entry.docker.ts",
    "dev": "bun run dev:workerd",
    "build": "bun run build:web",
    "build:web": "bun build ./src/web/index.tsx --outdir ./dist/web && cp ../../assets/logo.png ./dist/web/logo.png",
    "compile": "bun build ./src/entry.docker.ts --compile --outfile ../../dist/vantigo-idp",
    "compile:all": "bun run compile:linux-amd64 && bun run compile:linux-arm64 && bun run compile:mac-arm64 && bun run compile:windows-amd64",
    "compile:linux-amd64": "bun build ./src/entry.docker.ts --compile --target=bun-linux-x64 --outfile=../../dist/vantigo-idp-linux-amd64",
    "compile:linux-arm64": "bun build ./src/entry.docker.ts --compile --target=bun-linux-arm64 --outfile=../../dist/vantigo-idp-linux-arm64",
    "compile:mac-arm64": "bun build ./src/entry.docker.ts --compile --target=bun-darwin-arm64 --outfile=../../dist/vantigo-idp-darwin-arm64",
    "compile:windows-amd64": "bun build ./src/entry.docker.ts --compile --target=bun-windows-x64 --outfile=../../dist/vantigo-idp-windows-amd64.exe",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "docker:package": "docker buildx build --platform linux/amd64,linux/arm64 -t ghcr.io/vantigo-io/vantigo-idp:latest -f Dockerfile ../..",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "@mantine/core": "catalog:",
    "@mantine/hooks": "catalog:",
    "@tanstack/react-router": "catalog:",
    "better-auth": "catalog:",
    "i18next": "catalog:",
    "react-i18next": "catalog:",
    "@tabler/icons-react": "catalog:",
    "@vantigo/auth": "workspace:*",
    "@vantigo/ui": "workspace:*",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:",
    "pino": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "wrangler": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "drizzle-kit": "catalog:",
    "@types/bun": "catalog:",
    "@vantigo/config": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "testcontainers": "catalog:",
    "pino-pretty": "catalog:"
  }
}
